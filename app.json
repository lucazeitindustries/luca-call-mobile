{
  "expo": {
    "name": "Luca Call",
    "slug": "luca-call-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zeitindustries.lucacall",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Luca Call needs microphone access for voice conversations with your AI assistant.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.zeitindustries.lucacall",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Luca Call needs microphone access for voice conversations."
        }
      ]
    ]
  }
}
